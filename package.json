{
  "name": "peyzart-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && prisma db push && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,md,json}\"",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "mobile:dev": "CAP_SERVER_URL=http://localhost:3000 npx cap sync && npx cap run ios",
    "mobile:build": "next build && CAP_SERVER_URL=https://peyzart-core-gvizdors-projects.vercel.app npx cap sync && npx cap copy",
    "mobile:open:ios": "npx cap open ios",
    "mobile:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/status-bar": "^8.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "@stripe/stripe-js": "^9.1.0",
    "@types/three": "^0.183.1",
    "animejs": "^4.3.6",
    "autoprefixer": "^10.5.0",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "iyzipay": "^2.0.67",
    "lodash": "^4.18.1",
    "lucide-react": "^1.8.0",
    "mapbox-gl": "^3.25.0",
    "next": "16.2.3",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.1",
    "recharts": "^3.8.1",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/animejs": "^3.1.13",
    "@types/lodash": "^4.17.24",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.1.1",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
